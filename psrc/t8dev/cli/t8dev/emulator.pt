from    t8dev.cli.t8dev.emulator  import *

def test_suitename():
    t = RunCPM([])
    assert 'runcpm' == t.suitename()

def test_romsrcdir():
    t = CSCP([])
    assert str(t.romsrcdir('unit-test', 'romsrcdir', mkdir=False)) \
        .endswith('/.download/emulator/rom/cscp/unit-test/romsrcdir')
