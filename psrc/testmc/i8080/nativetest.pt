''' "Native" tests of the CPU simulator. (I.e., machine-language CPU test
    programs that run on the simulator itself.
'''

from    pathlib  import Path
import  pytest

from    binary.memimage  import MemImage
from    testmc.i8080 import  Machine
from    testmc.i8080.opcodes   import Instructions as I

TESTDATA_DIR = Path(__file__).parent
TPA_ADDR = 0x100
def load_com(m, filename):
    print(f'Loading {filename} from {TESTDATA_DIR}')
    with open(Path(TESTDATA_DIR, filename), 'rb') as f:
        #   XXX Should be able to load directly from file, w/o memimage!
        #   (As well as _load_asl(), etc., need _load_bin(startaddr).
        prog = MemImage()
        prog.addrec(TPA_ADDR, f.read())
        prog.entrypoint = TPA_ADDR
        m.load_memimage(prog, setPC=True)
    m.pc = TPA_ADDR

def test_8080pre(m):
    allok = 0x0327      # prints '8080 Preliminary tests complete' and exits
    load_com(m, 'programs/8080PRE.COM')
    #   The first few tests jump to $0000 on failure, so we set that
    #   to an instruction that will abort the simulator.
    m.deposit(0, I.HLT)
    m.stepto(stopat=[allok], trace=0)
    assert allok == m.pc

@pytest.mark.skip('Seems to run forever....')
def test_8080exer(m):
    load_com(m, 'programs/8080EXER.COM')
    while True:
        #   4e7 is ~5 min
        m.stepto(stopat=[0x0000, 0x0005], maxsteps=int(4e5), trace=0)
        if not cpm_bdos(m, 'z.8080exer'): break

def test_microcosm_diag(m):
    load_com(m, 'programs/TEST.COM')
    while True:
        m.stepto(stopat=[0x0000, 0x0005], trace=0)
        if not cpm_bdos(m): break
    assert 0, 'need to check output for pass fail indication'

def cpm_bdos(m, file='/dev/null'):
    ''' Emulate, within the test framework, a CPM BDOS call.
        This returns `True` if the test should continue runnning, or `False`
        if the test should exit successfully. (An exception will be raised
        on any type of failure.)

        The `file` parameter may be set to a filename (or ``'/dev/tty'``) to
        write output that file as well as to `stdout` for capture by pytest.

        This handles calls to the following addresses, which must be set
        in the `stopat` list for `Machine.stepto()`:
          • ``CALL $0000``: Exit.
          • ``CALL $0005``: CP/M BDOS function call.
        Any other addresses will be ignored, and `True` will be returned.
    '''
    m.deposit(0x0005, I.RET)    # Ensure we return from CP/M BDOS calls.
    with open(file, 'a') as f:
        def pr(*args, **kwargs):
            print(*args, **kwargs)
            print(*args, file=f, flush=True, **kwargs)

        if m.pc == 0x0000:
            pr(f'●Exit via $0000')
            return False
        if m.pc == 0x0005:      # BDOS call
            if m.c == 0x02:     # write character in E to console
                pr(f"{chr(m.e)}", end='')
            elif m.c == 0x09:   # write $-terminated string at DE to console
                terminator = m.mem.find(b'$', m.de)
                pr(m.bytes(m.de, terminator-m.de).decode('ASCII'))
            else:
                assert 0, 'Unknown BDOS call: ${:02X}'.format(m.c)
    return True

